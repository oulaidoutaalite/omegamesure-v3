# ─────────────────────────────────────────────────────────────
# Omega Mesure v3 — environment variables
# Copy to `.env` and fill in. `.env` must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────
# Pooled connection (used by the app at runtime).
# - Local PostgreSQL: postgresql://omega:omega@localhost:5432/omegamesure_v3?schema=public
# - Supabase: copy the "Transaction" connection string (port 6543) and
#   append `?pgbouncer=true&connection_limit=1` for serverless usage.
DATABASE_URL="postgresql://omega:omega@localhost:5432/omegamesure_v3?schema=public"

# Direct (session-pooler) connection used by `prisma migrate`.
# - Local: same as DATABASE_URL
# - Supabase: the "Session pooler" connection string (port 5432)
DIRECT_URL="postgresql://omega:omega@localhost:5432/omegamesure_v3?schema=public"

# Long random token to authorize the one-time /api/setup endpoint.
# `openssl rand -hex 24` produces a good value.
SETUP_TOKEN=""

# ─── NextAuth ────────────────────────────────────────────────
# Generate one with: `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-to-a-32+-char-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Omega Mesure"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"

# ─── Media uploads ───────────────────────────────────────────
# Default: store under /public/uploads on local disk.
UPLOAD_DIR="public/uploads"
MAX_UPLOAD_SIZE_MB="8"

# ─── Email (Resend by default) ───────────────────────────────
# Get a key at https://resend.com (free tier available)
RESEND_API_KEY=""
EMAIL_FROM="Omega Mesure <noreply@omegamesure.com>"
EMAIL_QUOTE_RECIPIENT="contact@omegamesure.com"

# ─── Initial seed admin ──────────────────────────────────────
# Leave SEED_ADMIN_PASSWORD empty to have the seed generate a strong random
# password (printed once). Never commit a real password here.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Site Admin"

# ─── (Optional) Cloudinary — not used in v3 initial setup ────
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
